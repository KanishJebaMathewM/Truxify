# Blockchain Module Environment Variables

# JSON-RPC provider URL for Polygon network (Amoy or Mainnet)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/

# Relayer/Deployer wallet private key (0x... format)
# RELAYER_PRIVATE_KEY is the preferred name; DEPLOYER_PRIVATE_KEY is accepted as fallback
RELAYER_PRIVATE_KEY=your_private_key_here

# Polygonscan API key for contract verification
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Initial Relayer wallet address (used in deploy.js)
RELAYER_WALLET_ADDRESS=your_relayer_wallet_address_here

# ─── Blockchain Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values

# Polygon Amoy Testnet RPC (get free at https://www.alchemy.com or https://infura.io)
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Your wallet private key for testnet deployment
# ⚠️ NEVER commit your real private key — use a throwaway testnet wallet
DEPLOYER_PRIVATE_KEY=your_testnet_wallet_private_key_here

# Polygonscan API key for contract verification (get at https://polygonscan.com/myapikey)
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here